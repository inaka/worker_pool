[
    {elvis, [
        {config, [
            #{
                dirs => ["src/**"],
                filter => "*.erl",
                ruleset => erl_files,
                rules =>
                    [
                        {elvis_style, no_invalid_dynamic_calls, #{
                            ignore => [wpool_process, wpool_time_checker]
