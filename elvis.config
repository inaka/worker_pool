                        {elvis_style, no_god_modules, #{limit => 30}},
                        {elvis_style, state_record_and_type, disable},
                        {elvis_style, dont_repeat_yourself, #{
                            ignore => [wpool_SUITE], min_complexity => 13
                        }}
                    ]
            },
            #{
                dirs => ["test"],
                filter => "*.erl",
                ruleset => erl_files,
                rules =>
                    [
                        {elvis_style, no_debug_call, disable},
